{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [ "DOM", "ESNext" ],
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "moduleResolution": "node"
  },
  "include": [ "src/**/*" ],
  "exclude": [ "node_modules", "dist" ]
}

